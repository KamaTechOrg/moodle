<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/mdl_capsule/db" VERSION="2025060500" COMMENT="XMLDB file for Moodle local/mdl_capsule"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">

  <TABLES>
    <!-- Each row in the table represents a capsule. -->
   
    <TABLE NAME="capsules" COMMENT="Main table for capsules data">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="capsuleid" TYPE="int" LENGTH="10"/>
        <FIELD NAME="cohortid" TYPE="int" LENGTH="10"/>
        <FIELD NAME="parentid" TYPE="int" LENGTH="10"/>
        <FIELD NAME="installerid" TYPE="int" LENGTH="10"/>
        <FIELD NAME="install_date" TYPE="int" LENGTH="10"/>
        <FIELD NAME="mac_address" TYPE="text"/>
        <FIELD NAME="status" TYPE="text"/>
        <FIELD NAME="last_update" TYPE="int" LENGTH="10"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- Here I keep a history of courses taken or associated with each capsule. -->

    <TABLE NAME="capsule_courses_log" COMMENT="History of course assignments for capsules">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="capsuleid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="child_capsuleid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="transferredon" TYPE="int" LENGTH="10"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- Here I keep commands that run on the capsule. -->

    <TABLE NAME="capsule_commands" COMMENT="Commands scheduled for capsules">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="capsuleid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="command" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- The log table — mdl_capsule_api_log What does it store? It doesn't
    store the data itself, but rather records: Which function was called.
    On what date. Who is the user. From what IP. Whether it succeeded (success = 1)
    or failed (success = 0). -->
   
    <TABLE NAME="capsule_api_log" COMMENT="Log table for API webservice calls">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10"/>
        <FIELD NAME="ip" TYPE="char" LENGTH="45" NOTNULL="true"/>
        <FIELD NAME="functionname" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="success" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>

  </TABLES>
</XMLDB>